{
  "name": "lamassu-js-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for the lamassu-js engine package, its web playground, and its docs site.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "web",
    "docs-site"
  ],
  "scripts": {
    "build:wasm": "make pkg",
    "build:web": "npm run build --workspace @mdy-docs/lamassu-playground",
    "build:docs": "npm run build --workspace @mdy-docs/lamassu-docs",
    "build": "npm run build:wasm && npm run build:web && npm run build:docs",
    "dev": "npm run dev --workspace @mdy-docs/lamassu-playground",
    "docs:dev": "npm run dev --workspace @mdy-docs/lamassu-docs",
    "docs:build": "npm run build --workspace @mdy-docs/lamassu-docs",
    "docs:preview": "npm run preview --workspace @mdy-docs/lamassu-docs"
  },
  "license": "MIT"
}
